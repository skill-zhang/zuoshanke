ue, reason}]\n186|  metrics: null,       // {mae, mape, rmse, r2}\n187|  chart: null,\n188|  anomalyChart: null,\n189|};\n190|\n191|// ============================================================\n192|// 工具函数\n193|// ============================================================\n194|function toast(msg, type='info') {\n195|  const el = document.createElement('div');\n196|  el.className = `toast ${type}`;\n197|  el.textContent = msg;\n198|  document.body.appendChild(el);\n199|  setTimeout(() => el.remove(), 3000);\n200|}\n201|\n202|function showError(msg) {\n203|  const el = document.getElementById('uploadError');\n204|  el.textContent = msg;\n205|  el.classList.remove('hidden');\n206|}\n207|\n208|function hideError() {\n209|  document.getElementById('uploadError').classList.add('hidden');\n210|}\n211|\n212|function updateDataStatus(text, type='gray') {\n213|  const el = document.getElementById('dataStatus');\n214|  el.textContent = text;\n215|  el.className = `text-xs px-3 py-1 rounded-full bg-${type}-100 text-${type}-700`;\n216|}\n217|\n218|// ============================================================\n219|// 文件上传与解析\n220|// ============================================================\n221|function handleFile(file) {\n222|  hideError();\n223|  if (!file) return;\n224|\n225|  const validTypes = ['.xlsx', '.xls', '.csv'];\n226|  const ext = '.' + file.name.split('.').pop().toLowerCase();\n227|  if (!validTypes.includes(ext)) {\n228|    showError('仅支持 .xlsx .xls .csv 格式');\n229|    return;\n230|  }\n231|\n232|  // 更新拖拽区\n233|  document.getElementById('dropContent').classList.add('hidden');\n234|  document.getElementById('fileInfo').classList.remove('hidden');\n235|  document.getElementById('fileName').textContent = file.name;\n236|  document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';\n237|  document.getElementById('dropZone').classList.add('has-file');\n238|\n239|  const reader = new FileReader();\n240|  reader.onload = function(e) {\n241|    try {\n242|      let data;\n243|      if (ext === '.csv') {\n244|        data = parseCSV(e.target.result);\n245|      } else {\n246|        data = parseXLSX(e.target.result);\n247|      }\n248|\n249|      if (!data || data.length === 0) {\n250|        showError('文件为空或无法解析');\n251|        return;\n252|      }\n253|\n254|      state.rawData = data;\n255|      state.headers = Object.keys(data[0]);\n256|      state.parsedRows = data;\n257|\n258|      populateColumnSelects();\n259|      renderTable(data);\n260|      updateDataStatus(`已加载 ${data.length} 行`, 'green');\n261|      toast(`成功加载 ${data.length} 行数据`, 'success');\n262|\n263|      // 启用运行按钮\n264|      document.getElementById('runBtn').disabled = false;\n265|\n266|    } catch(err) {\n267|      showError('解析失败: ' + err.message);\n268|      console.error(err);\n269|    }\n270|  };\n271|\n272|  if (ext === '.csv') {\n273|    reader.readAsText(file);\n274|  } else {\n275|    reader.readAsArrayBuffer(file);\n276|  }\n277|}\n278|\n279|function parseXLSX(buffer) {\n280|  const workbook = XLSX.read(buffer, { type: 'array' });\n281|  const sheet = workbook.Sheets[workbook.SheetNames[0]];\n282|  return XLSX.utils.sheet_to_json(sheet, { defval: null });\n283|}\n284|\n285|function parseCSV(text) {\n286|  const workbook = XLSX.read(text, { type: 'string' });\n287|  const sheet = workbook.Sheets[workbook.SheetNames[0]];\n288|  return XLSX.utils.sheet_to_json(sheet, { defval: null });\n289|}\n290|\n291|// 拖拽支持\n292|const dropZone = document.getElementById('dropZone');\n293|dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });\n294|dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('dragover'); });\n295|dropZone.addEventListener('drop', (e) => {\n296|  e.preventDefault();\n297|  dropZone.classList.remove('dragover');\n298|  const file = e.dataTransfer.files[0];\n299|  if (file) handleFile(file);\n300|});\n301|\n302|// ============================================================\n303|// 列选择 & 表格渲染\n304|// ============================================================\n305|function populateColumnSelects() {\n306|  const timeSelect = document.getElementById('timeCol');\n307|  const valueSelect = document.getElementById('valueCol');\n308|\n309|  timeSelect.innerHTML = '<option value=\"\">-- 选择时间列 --</option>';\n310|  valueSelect.innerHTML = '<option value=\"\">-- 选择数值列 --</option>';\n311|\n312|  state.headers.forEach(h => {\n313|    timeSelect.innerHTML += `<option value=\"${h}\">${h}</option>`;\n314|    valueSelect.innerHTML += `<option value=\"${h}\">${h}</option>`;\n315|  });\n316|\n317|  // 智能猜测：第一列是时间，第二列是数值\n318|  if (state.headers.length >= 2) {\n319|    timeSelect.value = state.headers[0];\n320|    valueSelect.value = state.headers[1];\n321|  }\n322|}\n323|\n324|function renderTable(data) {\n325|  const headers = Object.keys(data[0]);\n326|  const thead = document.getElementById('tableHead');\n327|  const tbody = document.getElementById('tableBody');\n328|\n329|  thead.innerHTML = headers.map(h => `<th>${h}</th>`).join('');\n330|\n331|  const maxRows = Math.min(data.length, 50);\n332|  tbody.innerHTML = data.slice(0, maxRows).map(row => {\n333|    return '<tr>' + headers.map(h => `<td>${row[h] !== null && row[h] !== undefined ? row[h] : ''}</td>`).join('') + '</tr>';\n334|  }).join('');\n335|\n336|  document.getElementById('rowCount').textContent = data.length;\n337|  document.getElementById('colCount').textContent = headers.length;\n338|  document.getElementById('noDataMsg').classList.add('hidden');\n339|}\n340|\n341|// ============================================================\n342|// 算法引擎\n343|// ============================================================\n344|\n345|// 准备数据：根据选中的列提取时间序列\n346|function prepareTimeSeries() {\n347|  const timeCol = document.getElementById('timeCol').value;\n348|  const valueCol = document.getElementById('valueCol').value;\n349|", "total_lines": 740, "offset": 150, "lim