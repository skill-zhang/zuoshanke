print(f\"[output] 自动提取 HTML 失败: {e}\")\n820|\n821|            # 🆕 检测 run_code 通过 code_b64 写入的 HTML 文件 → 注册为产出成果\n822|            try:\n823|                out_dir = Path(__file__).resolve().parent.parent.parent / \"outputs\" / scene_id\n824|                out_dir.mkdir(parents=True, exist_ok=True)\n825|                # 方式A：扫目录已有 .html 文件\n826|                if out_dir.exists():\n827|                    for html_file in sorted(out_dir.glob(\"*.html\")):\n828|                        fname = html_file.name\n829|                        fpath = f\"{scene_id}/{fname}\"\n830|                        existing = new_db.query(ProjectOutput).filter(\n831|                            ProjectOutput.file_path == fpath\n832|                        ).first()\n833|                        if existing:\n834|                            continue\n835|                        fsize = html_file.stat().st_size\n836|                        if fsize < 50:\n837|                            continue\n838|                        out_rec = ProjectOutput(\n839|                            id=make_id(\"out\"), scene_id=scene_id,\n840|                            title=f\"{scene.name or '产出'} - HTML\",\n841|                            description=f\"run_code 生成的 HTML 页面 ({fsize} 字节)\",\n842|                            type=\"html\", file_path=fpath,\n843|                        )\n844|                        new_db.add(out_rec); new_db.commit()\n845|                        yield sse_event(\"output:created\", output_id=out_rec.id,\n846|                            title=out_rec.title, file_path=out_rec.file_path)\n847|                        print(f\"[output] 目录扫描 HTML: {fpath}\")\n848|                # 方式B：从 run_code 的 stdout 中提取 HTML（LLM print(html) 场景）\n849|                for idx, tr in enumerate(agent_tool_results or []):\n850|                    if tr.get(\"tool\") == \"run_code\" and tr.get(\"success\"):\n851|                        stdout = (tr.get(\"result\") or {}).get(\"stdout\", \"\") if isinstance(tr.get(\"result\"), dict) else str(tr.get(\"result\", \"\"))\n852|                        # 方式B1：stdout 直接包含 HTML 内容\n853|                        if \"<!DOCTYPE html>\" in stdout or \"<html\" in stdout[:200]:\n854|                            html_start = stdout.find(\"<!DOCTYPE html>\")\n855|                            if html_start == -1:\n856|                                html_start = stdout.find(\"<html\")\n857|                            if html_start >= 0:\n858|                                html_content = stdout[html_start:].strip()\n859|                                if len(html_content) > 50:\n860|                                    safe_name = re.sub(r'[^\\w\\u4e00-\\u9fff_-]', '', scene.name or '产出')[:20]\n861|                                    out_path = out_dir / f\"run-{idx}.html\"\n862|                                    if out_path.exists():\n863|                                        out_path = out_dir / f\"run-{idx}-{ai_msg_id[:8]}.html\"\n864|                                    out_path.write_text(html_content, encoding=\"utf-8\")", "total_lines": 1168, "offset": 785, "limit": 80}, "duration_ms": 6}
