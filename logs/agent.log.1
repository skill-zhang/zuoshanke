{"ts": "2026-05-28T09:35:07.521", "scene": "scene-efab146c", "session": "", "step": 3, "type": "tool_done", "tool": "", "result": {"content": "1|#!/bin/bash\n2|# 坐山客 Gateway 启动/停止/状态脚本\n3|# Usage:\n4|#   bash scripts/gateway.sh start      # 启动 Gateway\n5|#   bash scripts/gateway.sh stop       # 停止 Gateway\n6|#   bash scripts/gateway.sh status     # 查看 Gateway 状态\n7|#   bash scripts/gateway.sh restart    # 重启 Gateway\n8|#   bash scripts/gateway.sh config     # 查看配置状态\n9|\n10|cd \"$(dirname \"$0\")/..\"  # 回到项目根目录\n11|BACKEND_DIR=\"$PWD/backend\"\n12|PID_FILE=\"$HOME/.zuoshanke/gateway.pid\"\n13|LOG_FILE=\"$HOME/.zuoshanke/gateway.log\"\n14|\n15|# 配置文件路径（新旧兼容）\n16|CONFIG_OLD=\"$HOME/.zuoshanke/.gateway.env\"\n17|CONFIG_NEW=\"$HOME/.zuoshanke/gateway.env\"\n18|\n19|mkdir -p \"$HOME/.zuoshanke\"\n20|\n21|start() {\n22|    if [ -f \"$PID_FILE\" ] && kill -0 \"$(cat \"$PID_FILE\")\" 2>/dev/null; then\n23|        echo \"⚠️  Gateway 已在运行 (PID: $(cat \"$PID_FILE\"))\"\n24|        return 1\n25|    fi\n26|\n27|    echo \"🚀 启动坐山客 Gateway v0.2 (多平台)...\"\n28|    echo \"   配置文件: $CONFIG_NEW (新版) / $CONFIG_OLD (旧版)\"\n29|\n30|    # 检测配置\n31|    if [ -f \"$CONFIG_NEW\" ]; then\n32|        echo \"   检测到新版配置，支持多平台\"\n33|        grep -E '^(WEIXIN|TELEGRAM|DISCORD|SIGNAL|EMAIL|SLACK|WHATSAPP|FEISHU|DINGTALK|WECOM|MATRIX|SMS|YYB)_' \"$CONFIG_NEW\" | \\\n34|            sed 's/=.*//' | sort -u | while read -r prefix; do\n35|            echo \"   📱 ${prefix%_*} 已配置\"\n36|        done\n37|    elif [ -f \"$CONFIG_OLD ]; then\n38|        echo \"   检测到旧版配置（仅微信）\"\n39|    else\n40|        echo \"   ⚠️  无配置文件，Gateway 退出\"\n41|    fi\n42|\n43|    cd \"$BACKEND_DIR\" && nohup \".venv/bin/python\" -m backend.gateway.run \\\n44|        >> \"$LOG_FILE\" 2>&1 &\n45|    PID=$!\n46|    echo $PID > \"$PID_FILE\"\n47|    echo \"✅ Gateway 已启动 (PID: $PID)\"\n48|    echo \"日志: $LOG_FILE\"\n49|    sleep 1\n50|    tail -3 \"$LOG_FILE\" 2>/dev/null || true\n51|}\n52|\n53|stop() {\n54|    if [ ! -f \"$PID_FILE\" ]; then\n55|        echo \"⚠️  PID 文件不存在\"\n56|        return 1\n57|    fi\n58|\n59|    PID=$(cat \"$PID_FILE\")\n60|    if kill -0 \"$PID\" 2>/dev/null; then\n61|        echo \"🛑 停止 Gateway (PID: $PID)...\"\n62|        kill \"$PID\" 2>/dev/null\n63|        sleep 2\n64|        if kill -0 \"$PID\" 2>/dev/null; then\n65|            echo \"强制终止...\"\n66|            kill -9 \"$PID\" 2>/dev/null\n67|        fi\n68|        rm -f \"$PID_FILE\"\n69|        echo \"✅ Gateway 已停止\"\n70|    else\n71|        echo \"⚠️  Gateway 未运行，清理 PID 文件\"\n72|        rm -f \"$PID_FILE\"\n73|    fi\n74|}\n75|\n76|status() {\n77|    if [ -f \"$PID_FILE\" ] && kill -0 \"$(cat \"$PID_FILE\")\" 2>/dev/null; then\n78|        PID=$(cat \"$PID_FILE\")\n79|        echo \"✅ Gateway 运行中 (PID: $PID)\"\n80|        echo \"日志文件: $LOG_FILE\"\n81|        echo \"最近日志:\"\n82|        tail -5 \"$LOG_FILE\" 2>/dev/null || echo \"(无日志)\"\n83|    else\n84|        echo \"❌ Gateway 未运行\"\n85|        if [ -f \"$PID_FILE\" ]; then\n86|            echo \"   (存在残留 PID 文件)\"\n87|        fi\n88|    fi\n89|}\n90|\n91|config_status() {\n92|    echo \"📋 Gateway 配置状态:\"\n93|    echo \"\"\n94|\n95|    if [ -f \"$CONFIG_NEW\" ]; then\n96|        echo \"  ✅ 新版配置文件: $CONFIG_NEW\"\n97|        echo \"\"\n98|        echo \"  已配置平台:\"\n99|        grep -v '^#' \"$CONFIG_NEW\" | grep -v '^$' | while IFS='=' read -r key value; do\n100|            # 提取平台前缀\n101|            prefix=\"${key%%_*}\"\n102|            case \"$prefix\" in\n103|                WEIXIN)\n104|                    if [ \"$key\" = \"WEIXIN_TOKEN\" ]; then\n105|                        echo \"  📱 微信 (iLink)\"\n106|                        echo \"     Token: ${value:0:8}...${value: -4}\"\n107|                    elif [ \"$key\" = \"WEIXIN_ACCOUNT_ID\" ]; then\n108|                        echo \"     Account: ${value:0:8}...\"\n109|                    fi\n110|                    ;;\n111|                TELEGRAM)\n112|                    if [ \"$key\" = \"TELEGRAM_TOKEN\" ]; then\n113|                        echo \"  📱 Telegram\"\n114|                        echo \"     Token: ${value:0:8}...${value: -4}\"\n115|                    fi\n116|                    ;;\n117|                DISCORD)\n118|                    if [ \"$key\" = \"DISCORD_BOT_TOKEN\" ]; then\n119|                        echo \"  📱 Discord\"\n120|                        echo \"     Token: ${value:0:8}...${value: -4}\"\n121|                    fi\n122|                    ;;\n123|                SIGNAL)\n124|                    if [ \"$key\" = \"SIGNAL_PHONE_NUMBER\" ]; then\n125|                        echo \"  📱 Signal\"\n126|                        echo \"     Phone: ${value:0:6}...${value: -4}\"\n127|                    fi\n128|                    ;;\n129|                EMAIL)\n130|                    if [ \"$key\" = \"EMAIL_SMTP_HOST\" ]; then\n131|                        echo \"  📧 Email: $value\"\n132|                    fi\n133|                    ;;\n134|                SLACK)\n135|                    if [ \"$key\" = \"SLACK_BOT_TOKEN\" ]; then\n136|                        echo \"  📱 Slack (已配置)\"\n137|                    fi\n138|                    ;;\n139|                WHATSAPP)\n140|                    if [ \"$key\" = \"WHATSAPP_PHONE_NUMBER_ID\" ]; then\n141|                        echo \"  📱 WhatsApp: $value\"\n142|                    fi\n143|                    ;;\n144|                FEISHU)\n145|                    if [ \"$key\" = \"FEISHU_APP_ID\" ]; then\n146|                        echo \"  📱 飞书: $value\"\n147|                    fi\n148|                    ;;\n149|                DINGTALK)\n150|                    if [ \"$key\" = \"DINGTALK_CLIENT_ID\" ]; then\n151|                        echo \"  📱 钉钉: $value\"\n152|                    fi\n153|                    ;;\n154|                WECOM)\n155|                    if [ \"$key\" = \"WECOM_CORP_ID\" ]; then\n156|                        echo \"  📱 企业微信: $value\"\n157|                    fi\n158|                    ;;\n159|                *)\n160|                    echo \"  📱 ${prefix}: (已配置)\"\n161|                    ;;\n162|            esac\n163|        done\n164|    elif [ -f \"$CONFIG_OLD ]; then\n165|        echo \"  ⚠️  旧版配置文件: $CONFIG_OLD\"\n166|        echo \"  建议迁移到新版格式: cp $CONFIG_OLD $CONFIG_NEW\"\n167|        echo \"\"\n168|        grep -v '^#' \"$CONFIG_OLD\" | grep -v '^$' | while IFS='=' read -r key value; do\n169|            if [ \"$key\" = \"WEIXIN_TOKEN\" ]; then\n170|                echo \"  📱 微信\"\n171|                echo \"     Token: ${value:0:8}...${value: -4}\"\n172|            elif [ \"$key\" = \"WEIXIN_ACCOUNT_ID\" ]; then\n173|                echo \"     Account: ${value:0:8}...\"\n174|            else\n175|                echo \"  $key: $value\"\n176|            fi\n177|        done\n178|    else\n179|        echo \"  ❌ 无配置文件\"\n180|        echo \"\"\n181|        echo \"  请创建配置文件:\"\n182|        echo \"    $CONFIG_NEW\"\n183|        echo \"\"\n184|        echo \"  示例内容:\"\n185|        echo \"    # 微信\"\n186|        echo \"    WEIXIN_TOKEN=your_token\"\n187|        echo \"    WEIXIN_ACCOUNT_ID=your_account_id\"\n188|        echo \"    # Telegram\"\n189|        echo \"    TELEGRAM_TOKEN=123456:ABC-DEF...\"\n190|        echo \"    # Discord\"\n191|        echo \"    DISCORD_BOT_TOKEN=your_discord_token\"\n192|    fi\n193|}\n194|\n195|case \"${1:-status}\" in\n196|    start) start ;;\n197|    stop) stop ;;\n198|    restart) stop; sleep 1; start ;;\n199|    status) status ;;\n200|    config) config_status ;;\n201|    *)\n202|        echo \"用法: $0 {start|stop|restart|status|config}\"\n203|        exit 1\n204|        ;;\n205|esac", "total_lines": 205, "offset": 1, "limit": 500}, "duration_ms": 5}
