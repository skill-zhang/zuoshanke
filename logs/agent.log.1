{"ts": "2026-05-28T09:35:07.514", "scene": "scene-efab146c", "session": "", "step": 3, "type": "tool_done", "tool": "", "result": {"content": "1|#!/usr/bin/env bash\n2|# ── 启动 Qwen LLM（llama-server）──\n3|# 用法:\n4|#   ./start-qwen.sh              # 启动 Qwen3.5-9B 多模态（默认，支持图片识别）\n5|#   ./start-qwen.sh text         # 启动 Qwen3-8B 纯文本\n6|#   ./start-qwen.sh stop         # 停掉当前 llama-server\n7|#   ./start-qwen.sh status       # 查看运行状态\n8|\n9|set -euo pipefail\n10|PORT=${QWEN_PORT:-8083}\n11|\n12|# ── 二进制路径 ──\n13|B9070=\"$HOME/llama-cpp/llama-b9070/llama-server\"      # ✅ 推荐：b9070 预编译版，Qwen3.5 多模态正常\n14|MASTER=\"$HOME/llama-cpp/llama-src/llama.cpp-master/build/bin/llama-server\"  # ⚠️ master 版 SSM 层有 bug\n15|SYSTEM=\"/usr/local/bin/llama-server\"                   # ⚠️ 旧全局安装版\n16|\n17|# ── 模型路径 ──\n18|MODEL_DIR=\"$HOME/models\"\n19|MODEL_35=\"$MODEL_DIR/Qwen3.5-9B-Q4_K_M.gguf\"   # 多模态（5.3GB）\n20|MMPROJ=\"$MODEL_DIR/mmproj-F16.gguf\"             # 多模态投影（876MB）\n21|MODEL_8B=\"$MODEL_DIR/Qwen3-8B-Q4_K_M.gguf\"     # 纯文本（4.7GB）\n22|\n23|# ── 公共参数 ──\n24|COMMON_ARGS=\"--host 0.0.0.0 --port $PORT -ngl 99 --ctx-size 16384 --threads 6 --temp 0.7 --repeat-penalty 1.1 --no-mmap --reasoning off\"\n25|\n26|stop_llama() {\n27|    local pids\n28|    pids=$(pgrep -f \"llama-server.*port $PORT\" 2>/dev/null || true)\n29|    if [ -n \"$pids\" ]; then\n30|        echo \"🔴 停掉 llama-server (PID: $pids)...\"\n31|        kill $pids 2>/dev/null || true\n32|        sleep 1\n33|        # 确认已停\n34|        if pgrep -f \"llama-server.*port $PORT\" >/dev/null 2>&1; then\n35|            echo \"   ⏳ 强制终止...\"\n36|            kill -9 $pids 2>/dev/null || true\n37|            sleep 1\n38|        fi\n39|        echo \"   ✅ 已停止\"\n40|    else\n41|        echo \"   ℹ️  没有运行中的 llama-server\"\n42|    fi\n43|}\n44|\n45|status_llama() {\n46|    local pids\n47|    pids=$(pgrep -f \"llama-server.*port $PORT\" 2>/dev/null || true)\n48|    if [ -n \"$pids\" ]; then\n49|        echo \"🟢 llama-server 正在运行\"\n50|        ps -p $pids -o pid,lstart,args --no-headers 2>/dev/null\n51|        echo \"\"\n52|        # 检查健康状态\n53|        if curl -sf http://localhost:$PORT/health >/dev/null 2>&1; then\n54|            echo \"   ✅ 健康检查通过\"\n55|            curl -s http://localhost:$PORT/v1/models 2>/dev/null | python3 -c \"\n56|import sys, json\n57|try:\n58|    d = json.load(sys.stdin)\n59|    for m in d.get('data', []):\n60|        caps = ', '.join(m.get('meta', {}).get('capabilities', m.get('capabilities', [])))\n61|        print(f'   📦 模型: {m[\\\"id\\\"]}')\n62|        print(f'   🔧 能力: {caps}')\n63|except: pass\n64|\" 2>/dev/null || true\n65|        else\n66|            echo \"   ⚠️  健康检查失败（可能正在加载中）\"\n67|        fi\n68|    else\n69|        echo \"🔴 llama-server 未运行\"\n70|    fi\n71|}\n72|\n73|case \"${1:-multimodal}\" in\n74|    stop)\n75|        stop_llama\n76|        exit 0\n77|        ;;\n78|    status)\n79|        status_llama\n80|        exit 0\n81|        ;;\n82|    restart)\n83|        stop_llama\n84|        exec \"$0\" \"${2:-multimodal}\"\n85|        ;;\n86|    text|8b)\n87|        echo \"🚀 启动 Qwen3-8B 纯文本（端口 $PORT）...\"\n88|        BIN=\"$B9070\"\n89|        MODEL=\"$MODEL_8B\"\n90|        MMARG=\"\"\n91|        shift 2>/dev/null || true\n92|        ;;\n93|    multimodal|35|9b|*)\n94|        echo \"🚀 启动 Qwen3.5-9B 多模态（端口 $PORT，支持图片识别）...\"\n95|        BIN=\"$B9070\"\n96|        MODEL=\"$MODEL_35\"\n97|        MMARG=\"--mmproj $MMPROJ\"\n98|        shift 2>/dev/null || true\n99|        ;;\n100|esac\n101|\n102|# 校验\n103|for f in \"$BIN\" \"$MODEL\"; do\n104|    if [ ! -f \"$f\" ]; then\n105|        echo \"❌ 文件不存在: $f\"\n106|        exit 1\n107|    fi\n108|done\n109|if [ -n \"$MMARG\" ] && [ ! -f \"$MMPROJ\" ]; then\n110|    echo \"❌ 多模态投影文件不存在: $MMPROJ\"\n111|    exit 1\n112|fi\n113|\n114|stop_llama\n115|\n116|echo \"   二进制: $BIN\"\n117|echo \"   模型:   $MODEL\"\n118|echo \"   端口:   $PORT\"\n119|echo \"\"\n120|\n121|# 在后台启动并确认\n122|nohup \"$BIN\" $COMMON_ARGS $MMARG > /tmp/llama-server.log 2>&1 &\n123|PID=$!\n124|echo \"   PID: $PID\"\n125|\n126|# 等待启动完成（最多 60 秒）\n127|echo \"   等待启动...\"\n128|for i in $(seq 1 60); do\n129|    if curl -sf http://localhost:$PORT/health >/dev/null 2>&1; then\n130|        echo \"   ✅ 启动成功（${i}s）\"\n131|        status_llama\n132|        exit 0\n133|    fi\n134|    sleep 1\n135|done\n136|\n137|echo \"❌ 启动超时（60s），查看日志: tail -50 /tmp/llama-server.log\"\n138|exit 1", "total_lines": 138, "offset": 1, "limit": 500}, "duration_ms": 5}
