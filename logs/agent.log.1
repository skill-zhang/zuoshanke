{"ts": "2026-05-28T11:04:28.773", "scene": "scene-efab146c", "session": "ws-cf47acb7", "step": 0, "type": "tool_done", "tool": "", "result": {"content": "1|#!/usr/bin/env bash\n2|# ── 坐山客一键恢复脚本 ──\n3|# 面向非 IT 用户，一键查看状态、自动修复异常服务\n4|#\n5|# 用法:\n6|#   ./zuoshanke-ctl.sh status       # 查看所有服务状态\n7|#   ./zuoshanke-ctl.sh fix          # 自动检测并修复异常服务\n8|#   ./zuoshanke-ctl.sh restart      # 一键重启所有服务\n9|#   ./zuoshanke-ctl.sh logs         # 查看所有日志\n10|#   ./zuoshanke-ctl.sh logs backend # 查看后端日志\n11|\n12|set -euo pipefail\n13|\n14|ZUOSHANKE_DIR=\"$HOME/zuoshanke\"\n15|SCRIPTS_DIR=\"$ZUOSHANKE_DIR/scripts\"\n16|BACKEND_PORT=8000\n17|FRONTEND_PORT=5173\n18|QWEEN_PORT=8083\n19|\n20|GREEN='\\033[0;32m'\n21|RED='\\033[0;31m'\n22|YELLOW='\\033[1;33m'\n23|NC='\\033[0m'\n24|\n25|log_ok()    { echo -e \" ${GREEN}✅${NC} $1\"; }\n26|log_err()   { echo -e \" ${RED}❌${NC} $1\"; }\n27|log_warn()  { echo -e \" ${YELLOW}⚠${NC}  $1\"; }\n28|\n29|check_port() { lsof -ti :\"$1\" >/dev/null 2>&1; }\n30|\n31|# ═══════════════════════════════════════════════\n32|#  状态查看\n33|# ═══════════════════════════════════════════════\n34|\n35|status() {\n36|    echo \"\"\n37|    echo \"═══════════ 坐山客服务状态 ═══════════\"\n38|    echo \"\"\n39|\n40|    # 后端\n41|    if check_port $BACKEND_PORT; then\n42|        local pid=$(lsof -ti :$BACKEND_PORT 2>/dev/null)\n43|        if curl -sf http://localhost:$BACKEND_PORT/api/channels >/dev/null 2>&1; then\n44|            log_ok \"后端 :$BACKEND_PORT (PID: $pid) — API 正常\"\n45|        else\n46|            log_warn \"后端 :$BACKEND_PORT (PID: $pid) — API 无响应\"\n47|        fi\n48|    else\n49|        log_err \"后端 :$BACKEND_PORT — 未运行\"\n50|    fi\n51|\n52|    # 前端\n53|    if check_port $FRONTEND_PORT; then\n54|        local pid=$(lsof -ti :$FRONTEND_PORT 2>/dev/null)\n55|        log_ok \"前端 :$FRONTEND_PORT (PID: $pid)\"\n56|    else\n57|        log_err \"前端 :$FRONTEND_PORT — 未运行\"\n58|    fi\n59|\n60|    # Qwen LLM\n61|    if check_port $QWEEN_PORT; then\n62|        log_ok \"Qwen LLM :$QWEEN_PORT\"\n63|    else\n64|        log_warn \"Qwen LLM :$QWEEN_PORT — 未运行\"\n65|    fi\n66|\n67|    # Gateway (Hermes)\n68|    if pgrep -f \"hermes_cli.*gateway\" >/dev/null 2>&1; then\n69|        local pid=$(pgrep -f \"hermes_cli.*gateway\" | head -1)\n70|        log_ok \"Gateway (PID: $pid)\"\n71|    else\n72|        log_err \"Gateway — 未运行\"\n73|    fi\n74|\n75|    # Uptime Kuma 监控面板\n76|    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q uptime-kuma; then\n77|        log_ok \"Uptime Kuma 监控面板 — 运行中 (http://localhost:3001)\"\n78|    else\n79|        log_warn \"Uptime Kuma 监控面板 — 未运行\"\n80|    fi\n81|\n82|    echo \"\"\n83|    echo \"═══════════════════════════════════════\"\n84|    echo \"\"\n85|}\n86|\n87|# ═══════════════════════════════════════════════\n88|#  一键修复（自动检测异常服务并重启）\n89|# ═══════════════════════════════════════════════\n90|\n91|fix() {\n92|    echo \"\"\n93|    echo \"🔍 检测异常服务...\"\n94|    echo \"\"\n95|    local fixed=0\n96|\n97|    # 后端\n98|    if ! check_port $BACKEND_PORT; then\n99|        log_warn \"后端异常，正在重启...\"\n100|        bash \"$SCRIPTS_DIR/start-zuoshanke.sh\" backend && fixed=$((fixed+1))\n101|    else\n102|        log_ok \"后端正常\"\n103|    fi\n104|\n105|    # 前端\n106|    if ! check_port $FRONTEND_PORT; then\n107|        log_warn \"前端异常，正在重启...\"\n108|        bash \"$SCRIPTS_DIR/start-zuoshanke.sh\" frontend && fixed=$((fixed+1))\n109|    else\n110|        log_ok \"前端正常\"\n111|    fi\n112|\n113|    # Gateway\n114|    if ! pgrep -f \"hermes_cli.*gateway\" >/dev/null 2>&1; then\n115|        log_warn \"Gateway 异常，正在重启...\"\n116|        bash \"$SCRIPTS_DIR/start-zuoshanke.sh\" gateway && fixed=$((fixed+1))\n117|    else\n118|        log_ok \"Gateway 正常\"\n119|    fi\n120|\n121|    # Uptime Kuma\n122|    if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q uptime-kuma; then\n123|        log_warn \"Uptime Kuma 异常，正在重启...\"\n124|        docker start uptime-kuma 2>/dev/null || \\\n125|        docker run -d --restart=always -p 3001:3001 -v uptime-kuma:/app/data --name uptime-kuma louislam/uptime-kuma:latest && \\\n126|        fixed=$((fixed+1))\n127|    else\n128|        log_ok \"Uptime Kuma 正常\"\n129|    fi\n130|\n131|    echo \"\"\n132|    if [ $fixed -eq 0 ]; then\n133|        log_ok \"所有服务运行正常，无需修复 🎉\"\n134|    else\n135|        log_ok \"已修复 $fixed 个异常服务\"\n136|    fi\n137|    echo \"\"\n138|    status\n139|}\n140|\n141|# ═══════════════════════════════════════════════\n142|#  查看日志\n143|# ═══════════════════════════════════════════════\n144|\n145|logs() {\n146|    local service=\"${1:-all}\"\n147|    case \"$service\" in\n148|        backend)\n149|            echo \"═══ 后端日志 (最后 50 行) ═══\"\n150|            tail -50 /tmp/zuoshanke-backend.log 2>/dev/null || echo \"(日志文件不存在)\"\n151|            ;;\n152|        frontend)\n153|            echo \"═══ 前端日志 (最后 50 行) ═══\"\n154|            tail -50 /tmp/zuoshanke-frontend.log 2>/dev/null || echo \"(日志文件不存在)\"\n155|            ;;\n156|        gateway)\n157|            echo \"═══ Gateway 日志 (最后 50 行) ═══\"\n158|            tail -50 /tmp/zuoshanke-gateway.log 2>/dev/null || echo \"(日志文件不存在)\"\n159|            ;;\n160|        kuma)\n161|            echo \"═══ Uptime Kuma 日志 (最后 50 行) ═══\"\n162|            docker logs --tail 50 uptime-kuma 2>/dev/null || echo \"(Uptime Kuma 未运行)\"\n163|            ;;\n164|        all)\n165|            echo \"═══ 后端日志 ═══\"\n166|            tail -20 /tmp/zuoshanke-backend.log 2>/dev/null || echo \"(无)\"\n167|            echo \"\"\n168|            echo \"═══ 前端日志 ═══\"\n169|            tail -20 /tmp/zuoshanke-frontend.log 2>/dev/null || echo \"(无)\"\n170|            echo \"\"\n171|            echo \"═══ Gateway 日志 ═══\"\n172|            tail -20 /tmp/zuoshanke-gateway.log 2>/dev/null || echo \"(无)\"\n173|            echo \"\"\n174|            echo \"═══ Uptime Kuma 日志 ═══\"\n175|            docker logs --tail 20 uptime-kuma 2>/dev/null || echo \"(Uptime Kuma 未运行)\"\n176|            ;;\n177|        *)\n178|            echo \"用法: $0 logs {backend|frontend|gateway|kuma|all}\"\n179|            exit 1\n180|            ;;\n181|    esac\n182|}\n183|\n184|# ═══════════════════════════════════════════════\n185|#  帮助\n186|# ═══════════════════════════════════════════════\n187|\n188|usage() {\n189|    echo \"坐山客一键恢复工具\"\n190|    echo \"\"\n191|    echo \"用法:\"\n192|    echo \"  $0 status       查看所有服务状态\"\n193|    echo \"  $0 fix          自动检测并修复异常服务\"\n194|    echo \"  $0 restart      一键重启所有服务\"\n195|    echo \"  $0 logs         查看所有日志\"\n196|    echo \"  $0 logs backend 查看后端日志\"\n197|    echo \"\"\n198|    echo \"示例:\"\n199|    echo \"  $0 status       # 看看哪个服务挂了\"\n200|    echo \"  $0 fix          # 自动修好\"\n201|}\n202|\n203|# ═══════════════════════════════════════════════\n204|#  主流程\n205|# ═══════════════════════════════════════════════\n206|\n207|case \"${1:-help}\" in\n208|    status)\n209|        status\n210|        ;;\n211|    fix)\n212|        fix\n213|        ;;\n214|    restart)\n215|        echo \"\"\n216|        echo \"🔄 一键重启所有服务...\"\n217|        bash \"$SCRIPTS_DIR/start-zuoshanke.sh\" restart\n218|        echo \"\"\n219|        status\n220|        ;;\n221|    logs)\n222|        logs \"${2:-all}\"\n223|        ;;\n224|    help|--help|-h)\n225|        usage\n226|        ;;\n227|    *)\n228|        echo \"未知命令: $1\"\n229|        echo \"\"\n230|        usage\n231|        exit 1\n232|        ;;\n233|esac", "total_lines": 233, "offset": 1, "limit": 500}, "duration_ms": 11}
