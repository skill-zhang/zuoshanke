stify-between mb-3\">\n144|          <h2 class=\"text-sm font-semibold text-gray-700\">📈 预测结果</h2>\n145|          <div id=\"predStatus\" class=\"text-xs text-gray-400\">等待运行</div>\n146|        </div>\n147|        <div id=\"chart\"></div>\n148|      </div>\n149|", "total_lines": 740, "offset": 50, "limit": 100}, "duration_ms": 5}
