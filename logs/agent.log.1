tAgentMessage;\n33|const selectSetAgentHidden = (s: any) => s.setAgentHidden;\n34|const selectIsGenerating = (s: any) => s.isGenerating;\n35|\n36|export default function App() {\n37|  const {\n38|    view, setView,\n39|    currentScene, setCurrentScene,\n40|    loadThinkingMap, loadSceneMessages,\n41|    channels, setCurrentChannel,\n42|    loadWorkshopScenes,\n43|    createSceneModalOpen, setCreateSceneModalOpen,\n44|    loadScenes, scenes,\n45|  } = useStore();\n46|\n47|  // ═══ 启动时加载 scenes + 工作台默认首页（仅首次） ═══\n48|  useEffect(() => {\n49|    loadScenes();\n50|  }, [loadScenes]);\n51|\n52|  const initialRouteRef = useRef(false);\n53|  useEffect(() => {\n54|    if (initialRouteRef.current) return; // 只执行一次\n55|    initialRouteRef.current = true;\n56|  }, [scenes]);\n57|\n58|  const [createName, setCreateName] = useState('');\n59|  const [createCategory, setCreateCategory] = useState('other');\n60|  const [createNewCategory, setCreateNewCategory] = useState('');\n61|  const [createUseNewCategory, setCreateUseNewCategory] = useState(false);\n62|  const [createDescription, setCreateDescription] = useState('');\n63|  const [creating, setCreating] = useState(false);\n64|\n65|  // 从 /api/health 获取版本号\n66|  const [version, setVersion] = useState('...');\n67|  useEffect(() => {\n68|    fetch('/api/health')\n69|      .then(r => r.json())\n70|      .then(d => setVersion(d.version || '?'))\n71|      .catch(() => setVersion('offline'));\n72|  }, []);\n73|\n74|  // ═══ 角色动画联动 — AI原生自洽（稳定选择器防 getSnapshot 警告） ═══\n75|  const agentStatus = useStore(selectAgentStatus);\n76|  const agentMessage = useStore(selectAgentMessage);\n77|  const agentHidden = useStore(selectAgentHidden);\n78|  const setAgentStatus = useStore(selectSetAgentStatus);\n79|  const setAgentMessage = useStore(selectSetAgentMessage);\n80|  const setAgentHidden = useStore(selectSetAgentHidden);", "total_lines": 403, "offset": 1, "limit": 80}, "duration_ms": 6}
