{"ts": "2026-05-28T23:05:24.158", "scene": "scene-b37c3f88", "session": "ws-63c903c2", "step": 20, "type": "tool_done", "tool": "read_file", "result": {"content": "550|  const r2 = ssTot !== 0 ? 1 - ssRes / ssTot : 0;\n551|\n552|  return { mae, mape, rmse, r2 };\n553|}\n554|\n555|// ============================================================\n556|// 主实验流程\n557|// ============================================================\n558|function runExperiment() {\n559|  const btn = document.getElementById('runBtn');\n560|  btn.disabled = true;\n561|  btn.innerHTML = '<span class=\"loading-spinner\"></span> 运行中...';\n562|\n563|  setTimeout(() => {\n564|    try {\n565|      // 1. 准备数据\n566|      const prepared = prepareTimeSeries();\n567|      if (!prepared) { btn.disabled = false; btn.innerHTML = '▶ 运行实验'; return; }\n568|\n569|      const algo = document.querySelector('input[name=\"predAlgo\"]:checked').value;\n570|      const anomAlgo = document.querySelector('input[name=\"anomAlgo\"]:checked').value;\n571|\n572|      // 2. 训练\n573|      let trainResult;\n574|      if (algo === 'movingAvg') trainResult = movingAvg(prepared.train);\n575|      else if (algo === 'expSmoothing') trainResult = expSmoothing(prepared.train);\n576|      else trainResult = prophetDecomp(prepared.train);\n577|\n578|      // 3. 预测测试集\n579|      const testPred = predictTest(trainResult, prepared.test, algo);\n580|      const fullPrediction = [...trainResult, ...testPred];\n581|\n582|      // 4. 异常检测（全量数据）\n583|      let anomalyResult;\n584|      if (anomAlgo === 'threeSigma') anomalyResult = threeSigmaDetect(prepared.series);\n585|      else if (anomAlgo === 'iqr') anomalyResult = iqrDetect(prepared.series);\n586|      else anomalyResult = slidingWindowDetect(prepared.series);\n587|\n588|      // 5. 评估指标（仅测试集）\n589|      const testActual = testPred.map(d => d.actual);\n590|      const testPredicted = testPred.map(d => d.predicted);\n591|      const metrics = calcMetrics(testActual, testPredicted);\n592|\n593|      // 6. 保存状态\n594|      state.prediction = fullPrediction;\n595|      state.anomalies = anomalyResult.filter(d => d.isAnomaly);\n596|      state.metrics = metrics;\n597|\n598|      // 7. 渲染\n599|      renderPredictionChart(fullPrediction, prepared.train.length);\n600|      renderAnomalyChart(anomalyResult);\n601|      renderMetrics(metrics);\n602|\n603|      document.getElementById('predStatus').textContent = `✅ 完成 | 算法: ${algo} | 异常检测: ${anomAlgo}`;\n604|      document.getElementById('predStatus').className = 'text-xs text-green-600';\n605|\n606|      const anomCount = anomalyResult.filter(d => d.isAnomaly).length;\n607|      document.getElementById('anomalyStats').classList.remove('hidden');\n608|      document.getElementById('anomalyStats').textContent = `检测到 ${anomCount} 个异常点 / 共 ${anomalyResult.length} 个数据点 (${(anomCount/anomalyResult.length*100).toFixed(1)}%)`;\n609|\n610|      toast('实验运行完成！', 'success');\n611|\n612|    } catch(err) {\n613|      toast('运行出错: ' + err.message, 'error');\n614|      console.error(err);\n615|    }\n616|\n617|    btn.disabled = false;\n618|    btn.innerHTML = '▶ 运行实验';\n619|  }, 100);\n620|}\n621|\n622|// ============================================================\n623|// 图表渲染\n624|// ============================================================\n625|\n626|function renderPredictionChart(data, splitIdx) {\n627|  if (!state.chart) {\n628|    state.chart = echarts.init(document.getElementById('chart'));\n629|  }\n630|\n631|  const times = data.map(d => d.time);\n632|  const actuals = data.map(d => d.actual);\n633|  const predicted = data.map(d => d.predicted);\n634|\n635|  // 训练/测试分界线\n636|  const markLineData = [{ xAxis: splitIdx > 0 ? times[splitIdx - 1] : times[0] }];\n637|\n638|  const option = {\n639|    tooltip: { trigger: 'axis' },\n640|    legend: { data: ['实际值', '预测值'], bottom: 0 },\n641|    grid: { left: 50, right: 20, top: 20, bottom: 40 },\n642|    xAxis: { type: 'category', data: times, axisLabel: { rotate: 45, fontSize: 10 } },\n643|    yAxis: { type: 'value', name: '数值' },\n644|    series: [\n645|      {\n646|        name: '实际值',\n647|        type: 'line',\n648|        data: actuals,\n649|        smooth: true,\n650|        lineStyle: { width: 2, color: '#3b82f6' },\n651|        symbol: 'none',\n652|        markLine: {\n653|          silent: true,\n654|          data: [{ xAxis: times[splitIdx] || times[Math.floor(times.length * 0.8)], label: { formatter: '训练/测试分界', fontSize: 10 } }],\n655|          lineStyle: { type: 'dashed', color: '#f59e0b' }\n656|        }\n657|      },\n658|      {\n659|        name: '预测值',\n660|        type: 'line',\n661|        data: predicted,\n662|        smooth: true,\n663|        lineStyle: { width: 2, color: '#ef4444', type: 'dashed' },\n664|        symbol: 'none'\n665|      }\n666|    ]\n667|  };\n668|\n669|  state.chart.setOption(option, true);\n670|  state.chart.resize();\n671|}\n672|\n673|function renderAnomalyChart(data) {\n674|  if (!state.anomalyChart) {\n675|    state.anomalyChart = echarts.init(document.getElementById('anomalyChart'));\n676|  }\n677|\n678|  const times = data.map(d => d.time);\n679|  const values = data.map(d => d.value);\n680|  const anomalyTimes = data.filter(d => d.isAnomaly).map(d => d.time);\n681|  const anomalyValues = data.filter(d => d.isAnomaly).map(d => d.value);\n682|\n683|  const option = {\n684|    tooltip: { trigger: 'axis' },\n685|    legend: { data: ['数据值', '异常点'], bottom: 0 },\n686|    grid: { left: 50, right: 20, top: 20, bottom: 40 },\n687|    xAxis: { type: 'category', data: times, axisLabel: { rotate: 45, fontSize: 10 } },\n688|    yAxis: { type: 'value', name: '数值' },\n689|    series: [\n690|      {\n691|        name: '数据值',\n692|        type: 'line',\n693|        data: values,\n694|        smooth: true,\n695|        lineStyle: { width: 1.5, color: '#94a3b8' },\n696|        symbol: 'none'\n697|      },\n698|      {\n699|        name: '异常点',\n700|        type: 'scatter',\n701|        data: anomalyTimes.map((t, i) => [t, anomalyValues[i]]),\n702|        symbolSize: 12,\n703|        itemStyle: { color: '#ef4444', borderColor: '#fff', borderWidth: 2 }\n704|      }\n705|    ]\n706|  };\n707|\n708|  state.anomalyChart.setOption(option, true);\n709|  state.anomalyChart.resize();\n710|}\n711|\n712|function renderMetrics(metrics) {\n713|  if (!metrics) return;\n714|\n715|  document.getElementById('metricsEmpty').classList.add('hidden');\n716|\n717|  const cards = document.querySelectorAll('.metric-card');\n718|  const labels = ['MAE', 'MAPE', 'RMSE', 'R²'];\n719|  const values = [metrics.mae, metrics.mape, metrics.rmse, metrics.r2];\n720|  const formats = [v => v.toFixed(4), v => v.toFixed(2) + '%', v => v.toFixed(4), v => v.toFixed(4)];\n721|\n722|  cards.forEach((card, i) => {\n723|    card.querySelector('.value').textContent = formats[i](values[i]);\n724|    card.querySelector('.label').textContent = labels[i];\n725|  });\n726|}\n727|\n728|// ============================================================\n729|// 窗口大小自适应\n730|// ============================================================\n731|window.addEventListener('resize', () => {\n732|  if (state.chart) state.chart.resize();\n733|  if (state.anomalyChart) state.anomalyChart.resize();\n734|});\n735|\n736|// 初始化完成\n737|console.log('🧪 算法实验平台 MVP 已加载');\n738|</script>\n739|</body>", "total_lines": 740, "offset": 550, "limit": 190}, "duration_ms": 6}
