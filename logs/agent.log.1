mport SessionLocal as _DL\n63|        from agent_core.memory_cache import MemoryCache\n64|        _db = _DL()\n65|        MemoryCache.get_instance().initialize(_db)\n66|        _db.close()\n67|        log.info(\"✅ MemoryCache 已加载本体记忆\")\n68|    except Exception as e:\n69|        log.warning(f\"MemoryCache 初始化跳过: {e}\")\n70|\n71|    # 🆕 Schema v0.8: 初始化坐山客本体（如无则创建）\n72|    try:\n73|        from database import SessionLocal\n74|        from agent_core.zhu_agent import ZhuAgentManager\n75|        db = SessionLocal()\n76|        ZhuAgentManager(db).get_or_create()\n77|        db.close()\n78|        log.info(\"✅ 坐山客本体已就绪\")\n79|    except Exception as e:\n80|        log.warning(f\"本体初始化跳过: {e}\")", "total_lines": 253, "offset": 1, "limit": 80}, "duration_ms": 5}
