{"ts": "2026-05-28T23:05:22.376", "scene": "scene-b37c3f88", "session": "ws-63c903c2", "step": 19, "type": "tool_done", "tool": "read_file", "result": {"content": "350|  if (!timeCol || !valueCol) {\n351|    toast('请选择时间列和数值列', 'error');\n352|    return null;\n353|  }\n354|\n355|  state.timeCol = timeCol;\n356|  state.valueCol = valueCol;\n357|\n358|  const series = state.rawData.map((row, i) => {\n359|    let t = row[timeCol];\n360|    let v = parseFloat(row[valueCol]);\n361|    return { time: t !== null && t !== undefined ? String(t) : `#${i}`, value: isNaN(v) ? null : v };\n362|  }).filter(d => d.value !== null);\n363|\n364|  if (series.length < 10) {\n365|    toast('有效数据点不足10个，请检查数值列', 'error');\n366|    return null;\n367|  }\n368|\n369|  // 训练/测试划分\n370|  const ratio = parseInt(document.getElementById('trainRatio').value) / 100;\n371|  const splitIdx = Math.floor(series.length * ratio);\n372|\n373|  state.trainData = series.slice(0, splitIdx);\n374|  state.testData = series.slice(splitIdx);\n375|\n376|  return { series, train: state.trainData, test: state.testData };\n377|}\n378|\n379|// ----- 时序预测算法 -----\n380|\n381|// 移动平均\n382|function movingAvg(train, windowSize) {\n383|  windowSize = windowSize || Math.max(3, Math.floor(train.length * 0.1));\n384|  const result = [];\n385|  for (let i = 0; i < train.length; i++) {\n386|    const start = Math.max(0, i - windowSize + 1);\n387|    const slice = train.slice(start, i + 1);\n388|    const avg = slice.reduce((s, d) => s + d.value, 0) / slice.length;\n389|    result.push({ time: train[i].time, actual: train[i].value, predicted: avg });\n390|  }\n391|  return result;\n392|}\n393|\n394|// 指数平滑\n395|function expSmoothing(train, alpha) {\n396|  alpha = alpha || 0.3;\n397|  const result = [];\n398|  let prev = train[0].value;\n399|  result.push({ time: train[0].time, actual: train[0].value, predicted: train[0].value });\n400|  for (let i = 1; i < train.length; i++) {\n401|    const smoothed = alpha * train[i].value + (1 - alpha) * prev;\n402|    result.push({ time: train[i].time, actual: train[i].value, predicted: smoothed });\n403|    prev = smoothed;\n404|  }\n405|  return result;\n406|}\n407|\n408|// Prophet 风格分解（STL分解简化版）\n409|function prophetDecomp(train, period) {\n410|  period = period || Math.max(2, Math.floor(train.length * 0.2));\n411|  const n = train.length;\n412|  const values = train.map(d => d.value);\n413|\n414|  // 1. 趋势分量：移动平均\n415|  const trend = [];\n416|  for (let i = 0; i < n; i++) {\n417|    const start = Math.max(0, i - Math.floor(period/2));\n418|    const end = Math.min(n, i + Math.floor(period/2) + 1);\n419|    const slice = values.slice(start, end);\n420|    trend.push(slice.reduce((s, v) => s + v, 0) / slice.length);\n421|  }\n422|\n423|  // 2. 季节性分量：周期平均\n424|  const detrended = values.map((v, i) => v - trend[i]);\n425|  const seasonal = new Array(n).fill(0);\n426|  for (let i = 0; i < n; i++) {\n427|    let sum = 0, count = 0;\n428|    for (let j = i % period; j < n; j += period) {\n429|      sum += detrended[j];\n430|      count++;\n431|    }\n432|    seasonal[i] = count > 0 ? sum / count : 0;\n433|  }\n434|\n435|  // 3. 预测 = 趋势 + 季节性\n436|  const result = [];\n437|  for (let i = 0; i < n; i++) {\n438|    result.push({\n439|      time: train[i].time,\n440|      actual: train[i].value,\n441|      predicted: trend[i] + seasonal[i]\n442|    });\n443|  }\n444|  return result;\n445|}\n446|\n447|// 预测测试集（用最后一个训练点的预测方法外推）\n448|function predictTest(trainResult, testData, algo) {\n449|  const lastPred = trainResult[trainResult.length - 1];\n450|  const lastActual = trainResult[trainResult.length - 1].actual;\n451|  const trainValues = trainResult.map(d => d.actual);\n452|\n453|  return testData.map((d, i) => {\n454|    let predicted;\n455|    if (algo === 'movingAvg') {\n456|      // 用最近窗口的平均值\n457|      const window = Math.max(3, Math.floor(trainValues.length * 0.1));\n458|      const recent = [...trainValues.slice(-window), ...testData.slice(0, i).map(x => x.value)];\n459|      predicted = recent.reduce((s, v) => s + v, 0) / recent.length;\n460|    } else if (algo === 'expSmoothing') {\n461|      // 指数平滑外推\n462|      const alpha = 0.3;\n463|      const prev = i === 0 ? lastActual : testData[i-1].value;\n464|      predicted = alpha * prev + (1 - alpha) * (i === 0 ? lastPred.predicted : testData[i-1].value);\n465|    } else {\n466|      // Prophet: 用最后一个趋势+季节性\n467|      const period = Math.max(2, Math.floor(trainValues.length * 0.2));\n468|      const trendSlope = (trainResult[trainResult.length-1].predicted - trainResult[Math.max(0, trainResult.length-11)].predicted) / Math.min(10, trainResult.length);\n469|      const seasonIdx = (trainResult.length + i) % period;\n470|      const seasonalOffset = trainResult.filter((_, idx) => idx % period === seasonIdx).reduce((s, x) => s + (x.predicted - x.actual), 0) / Math.max(1, trainResult.filter((_, idx) => idx % period === seasonIdx).length);\n471|      predicted = lastPred.predicted + trendSlope * (i + 1) + seasonalOffset;\n472|    }\n473|    return { time: d.time, actual: d.value, predicted: Math.max(0, predicted) };\n474|  });\n475|}\n476|\n477|// ----- 异常检测算法 -----\n478|\n479|// 3σ 检测\n480|function threeSigmaDetect(data) {\n481|  const values = data.map(d => d.value);\n482|  const mean = values.reduce((s, v) => s + v, 0) / values.length;\n483|  const std = Math.sqrt(values.reduce((s, v) => s + (v - mean) ** 2, 0) / values.length);\n484|  const threshold = 3 * std;\n485|\n486|  return data.map(d => ({\n487|    ...d,\n488|    isAnomaly: Math.abs(d.value - mean) > threshold,\n489|    reason: Math.abs(d.value - mean) > threshold ? `|${d.value.toFixed(2)} - μ(${mean.toFixed(2)})| > 3σ(${threshold.toFixed(2)})` : ''\n490|  }));\n491|}\n492|\n493|// IQR 检测\n494|function iqrDetect(data) {\n495|  const values = data.map(d => d.value).sort((a, b) => a - b);\n496|  const q1 = values[Math.floor(values.length * 0.25)];\n497|  const q3 = values[Math.floor(values.length * 0.75)];\n498|  const iqr = q3 - q1;\n499|  const lower = q1 - 1.5 * iqr;\n500|  const upper = q3 + 1.5 * iqr;\n501|\n502|  return data.map(d => ({\n503|    ...d,\n504|    isAnomaly: d.value < lower || d.value > upper,\n505|    reason: d.value < lower ? `低于下界 ${lower.toFixed(2)}` : d.value > upper ? `高于上界 ${upper.toFixed(2)}` : ''\n506|  }));\n507|}\n508|\n509|// 滑动窗口检测\n510|function slidingWindowDetect(data, windowSize) {\n511|  windowSize = windowSize || Math.max(5, Math.floor(data.length * 0.05));\n512|  const result = [];\n513|  for (let i = 0; i < data.length; i++) {\n514|    const start = Math.max(0, i - windowSize);\n515|    const window = data.slice(start, i);\n516|    if (window.length < 3) {\n517|      result.push({ ...data[i], isAnomaly: false, reason: '' });\n518|      continue;\n519|    }\n520|    const mean = window.reduce((s, d) => s + d.value, 0) / window.length;\n521|    const std = Math.sqrt(window.reduce((s, d) => s + (d.value - mean) ** 2, 0) / window.length);\n522|    const threshold = 3 * std;\n523|    result.push({\n524|      ...data[i],\n525|      isAnomaly: Math.abs(data[i].value - mean) > threshold,\n526|      reason: Math.abs(data[i].value - mean) > threshold ? `窗口均值=${mean.toFixed(2)}, 阈值=${threshold.toFixed(2)}` : ''\n527|    });\n528|  }\n529|  return result;\n530|}\n531|\n532|// ============================================================\n533|// 评估指标\n534|// ============================================================\n535|function calcMetrics(actual, predicted) {\n536|  const n = actual.length;\n537|  if (n === 0) return null;\n538|\n539|  const errors = actual.map((a, i) => a - predicted[i]);\n540|  const absErrors = errors.map(e => Math.abs(e));\n541|  const sqErrors = errors.map(e => e * e);\n542|\n543|  const mae = absErrors.reduce((s, v) => s + v, 0) / n;\n544|  const mape = absErrors.reduce((s, v, i) => s + (actual[i] !== 0 ? v / Math.abs(actual[i]) : 0), 0) / n * 100;\n545|  const rmse = Math.sqrt(sqErrors.reduce((s, v) => s + v, 0) / n);\n546|\n547|  const meanActual = actual.reduce((s, v) => s + v, 0) / n;\n548|  const ssRes = sqErrors.reduce((s, v) => s + v, 0);\n549|  const ssTot = actual.reduce((s, v) => s + (v - meanActual) ** 2, 0);", "total_lines": 740, "offset": 350, "limit": 200}, "duration_ms": 5}
