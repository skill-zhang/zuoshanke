{"ts": "2026-05-28T21:59:20.067", "scene": "scene-b37c3f88", "session": "ws-63c903c2", "step": 18, "type": "tool_done", "tool": "read_file", "result": {"content": "1|\"\"\"文件上传端点 — 支持图片和文档上传，返回可访问的 URL\"\"\"\n2|\n3|import logging\n4|import os\n5|import uuid\n6|from pathlib import Path\n7|from typing import Optional\n8|\n9|from fastapi import APIRouter, HTTPException, UploadFile, File, Form\n10|from fastapi.responses import JSONResponse\n11|\n12|_log = logging.getLogger(__name__)\n13|\n14|# 上传目录\n15|UPLOAD_DIR = Path(__file__).resolve().parent.parent.parent / \"uploads\"\n16|UPLOAD_DIR.mkdir(exist_ok=True)\n17|\n18|# 允许的图片 MIME 类型\n19|ALLOWED_IMAGE_TYPES = {\n20|    \"image/jpeg\", \"image/png\", \"image/gif\", \"image/webp\", \"image/bmp\",\n21|}\n22|# 允许的文档 MIME 类型\n23|ALLOWED_DOC_TYPES = {\n24|    \"application/pdf\",\n25|    \"text/plain\",\n26|    \"application/json\",\n27|    \"text/csv\",\n28|    \"application/msword\",\n29|    \"application/vnd.openxmlformats-officedocument.wordprocessingml.document\",\n30|    \"application/vnd.ms-excel\",\n31|    \"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet\",\n32|    \"text/markdown\",\n33|    \"application/zip\",\n34|    \"application/gzip\",\n35|}\n36|ALLOWED_IMAGE_EXT = {\".jpg\", \".jpeg\", \".png\", \".gif\", \".webp\", \".bmp\"}\n37|ALLOWED_DOC_EXT = {\".pdf\", \".txt\", \".json\", \".csv\", \".doc\", \".docx\", \".xls\", \".xlsx\", \".md\", \".zip\", \".gz\"}\n38|\n39|router = APIRouter(tags=[\"上传\"])\n40|\n41|\n42|def _is_allowed(filename: str, content_type: str) -> tuple[bool, str]:\n43|    \"\"\"检查文件是否允许上传，返回 (ok, file_type) 其中 file_type 为 'image' / 'doc' / ''\"\"\"\n44|    ext = Path(filename).suffix.lower()\n45|    if content_type in ALLOWED_IMAGE_TYPES or ext in ALLOWED_IMAGE_EXT:\n46|        return True, \"image\"\n47|    if ext in ALLOWED_DOC_EXT:\n48|        return True, \"doc\"\n49|    return False, \"\"\n50|\n51|\n52|@router.post(\"/api/upload\")\n53|async def upload_file(file: UploadFile = File(...)):\n54|    \"\"\"上传文件，返回可访问的 URL\n55|\n56|    Returns:\n57|        {\"url\": \"http://localhost:8000/uploads/xxx.jpg\",\n58|         \"file_type\": \"image\"|\"doc\",\n59|         \"filename\": \"xxx.jpg\",\n60|         \"size\": 12345}\n61|    \"\"\"\n62|    if not file.filename:\n63|        raise HTTPException(400, \"文件名为空\")\n64|\n65|    # 检查文件类型\n66|    content_type = file.content_type or \"\"\n67|    ok, file_type = _is_allowed(file.filename, content_type)\n68|    if not ok:\n69|        raise HTTPException(400,\n70|            f\"不支持的文件类型: {content_type or file.filename}。\"\n71|            f\"图片支持: {', '.join(sorted(ALLOWED_IMAGE_EXT))}；\"\n72|            f\"文档支持: {', '.join(sorted(ALLOWED_DOC_EXT))}。\"\n73|        )\n74|\n75|    # 生成唯一文件名\n76|    ext = Path(file.filename).suffix.lower()\n77|    unique_name = f\"{uuid.uuid4().hex}{ext}\"\n78|    save_path = UPLOAD_DIR / unique_name\n79|\n80|    # 保存文件\n81|    try:\n82|        content = await file.read()\n83|        # 文件大小限制：50MB\n84|        if len(content) > 50 * 1024 * 1024:\n85|            raise HTTPException(413, \"文件过大，最大支持 50MB\")\n86|        save_path.write_bytes(content)\n87|    except HTTPException:\n88|        raise\n89|    except Exception as e:\n90|        _log.error(f\"[upload] 保存文件失败: {e}\")\n91|        raise HTTPException(500, f\"文件保存失败: {e}\")\n92|\n93|    # 构造访问 URL\n94|    url = f\"/uploads/{unique_name}\"\n95|\n96|    return JSONResponse({\n97|        \"url\": url,\n98|        \"file_type\": file_type,\n99|        \"filename\": file.filename,\n100|        \"size\": len(content),\n101|    })", "total_lines": 101, "offset": 1, "limit": 500}, "duration_ms": 7}
