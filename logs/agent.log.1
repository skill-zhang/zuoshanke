22|\n123|  const recordActivity = useCallback(() => {\n124|    lastActivityRef.current = Date.now();\n125|    if (isIdle) {\n126|      setIsIdle(false);\n127|      setAgentHidden(false);\n128|    }\n129|  }, [isIdle]);\n130|\n131|  // 全局监听用户操作\n132|  useEffect(() => {\n133|    const handler = () => recordActivity();\n134|    window.addEventListener('mousedown', handler);\n135|    window.addEventListener('keydown', handler);\n136|    window.addEventListener('touchstart', handler);\n137|    return () => {\n138|      window.removeEventListener('mousedown', handler);\n139|      window.removeEventListener('keydown', handler);\n140|      window.removeEventListener('touchstart', handler);\n141|    };\n142|  }, [recordActivity]);\n143|\n144|  // 空闲检测循环\n145|  useEffect(() => {\n146|    idleCheckRef.current = setInterval(() => {\n147|      if (isGenerating) return;\n148|      const elapsed = Date.now() - lastActivityRef.current;\n149|      if (elapsed > 25000 && !isIdle) {\n150|        setIsIdle(true);\n151|      } else if (elapsed > 180000) {\n152|        // 3分钟无操作 → 去睡觉\n153|        setAgentHidden(true);\n154|      } else if (elapsed < 25000 && isIdle) {\n155|        setIsIdle(false);\n156|        setAgentHidden(false);\n157|      }\n158|    }, 3000);\n159|    return () => { if (idleCheckRef.current) clearInterval(idleCheckRef.current); };\n160|  }, [isGenerating, isIdle]);\n161|\n162|  // 空闲时自娱自乐\n163|  useEffect(() => {\n164|    if (!isIdle) {\n165|      if (entertainRef.current) { clearInterval(entertainRef.current); entertainRef.current = null; }\n166|      return;\n167|    }\n168|    // 初始随机延迟后开始娱乐\n169|    const startDelay = setTimeout(() => {\n170|      entertainRef.current = setInterval(() => {\n171|        const pick = entertainments[Math.floor(Math.random() * entertainments.length)];\n172|        setAgentStatus(pick.status);\n173|        setAgentMessage(pick.msg);\n174|      }, 5000 + Math.random() * 7000);\n175|    }, 3000 + Math.random() * 5000);\n176|    retur