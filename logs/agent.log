{"ts": "2026-05-28T09:35:07.506", "scene": "scene-efab146c", "session": "", "step": 3, "type": "tool_done", "tool": "", "result": {"content": "1|#!/usr/bin/env bash\n2|# ── 启动坐山客（zuoshanke）全套服务 ──\n3|# 用法:\n4|#   start-zuoshanke.sh              # 启动全部（后端 + 前端）\n5|#   start-zuoshanke.sh backend      # 仅启动后端\n6|#   start-zuoshanke.sh frontend     # 仅启动前端\n7|#   start-zuoshanke.sh gateway      # 仅启动 Hermes 消息网关\n8|#   start-zuoshanke.sh all          # 同上，全部启动\n9|#   start-zuoshanke.sh stop         # 停掉全部\n10|#   start-zuoshanke.sh status       # 查看运行状态\n11|\n12|set -euo pipefail\n13|\n14|ZUOSHANKE_DIR=\"$HOME/zuoshanke\"\n15|BACKEND_DIR=\"$ZUOSHANKE_DIR/backend\"\n16|FRONTEND_DIR=\"$ZUOSHANKE_DIR/frontend\"\n17|BACKEND_PORT=8000\n18|FRONTEND_PORT=5173\n19|\n20|# ── pnpm 不在默认 PATH ──\n21|PNPM=\"$HOME/.hermes/node/bin/pnpm\"\n22|\n23|# ── 颜色 ──\n24|GREEN='\\033[0;32m'\n25|RED='\\033[0;31m'\n26|YELLOW='\\033[1;33m'\n27|NC='\\033[0m' # No Color\n28|\n29|log_info()  { echo -e \" ${GREEN}ℹ${NC}  $1\"; }\n30|log_ok()    { echo -e \" ${GREEN}✅${NC} $1\"; }\n31|log_err()   { echo -e \" ${RED}❌${NC} $1\"; }\n32|log_warn()  { echo -e \" ${YELLOW}⚠${NC}  $1\"; }\n33|\n34|# ── 日志文件 ──\n35|BACKEND_LOG=\"/tmp/zuoshanke-backend.log\"\n36|FRONTEND_LOG=\"/tmp/zuoshanke-frontend.log\"\n37|GATEWAY_LOG=\"/tmp/zuoshanke-gateway.log\"\n38|\n39|# ═══════════════════════════════════════════════\n40|#  检查 & 停止\n41|# ═══════════════════════════════════════════════\n42|\n43|stop_service() {\n44|    local name=\"$1\" port=\"$2\" pid_var=\"$3\"\n45|    local pids\n46|    pids=$(pgrep -f \"$port\" 2>/dev/null || true)\n47|    if [ -z \"$pids\" ]; then\n48|        pids=$(lsof -ti :\"$port\" 2>/dev/null || true)\n49|    fi\n50|    if [ -n \"$pids\" ]; then\n51|        log_warn \"停掉 $name (PID: $(echo $pids | tr '\\n' ' '))...\"\n52|        kill $pids 2>/dev/null || true\n53|        sleep 1\n54|        if lsof -ti :\"$port\" >/dev/null 2>&1; then\n55|            log_warn \"  强制终止...\"\n56|            kill -9 $pids 2>/dev/null || true\n57|            sleep 1\n58|        fi\n59|        log_ok \"$name 已停止\"\n60|    fi\n61|}\n62|\n63|stop_gateway() {\n64|    if ps -p \"$GATEWAY_PID\" >/dev/null 2>&1; then\n65|        log_warn \"停掉 Gateway...\"\n66|        python3 -m hermes_cli.main gateway stop 2>/dev/null || true\n67|        kill \"$GATEWAY_PID\" 2>/dev/null || true\n68|        sleep 1\n69|        log_ok \"Gateway 已停止\"\n70|    fi\n71|}\n72|\n73|stop_all() {\n74|    stop_service \"后端\" \"$BACKEND_PORT\" \"\"\n75|    stop_service \"前端\" \"$FRONTEND_PORT\" \"\"\n76|    stop_gateway\n77|    log_ok \"全部服务已停止\"\n78|}\n79|\n80|# ═══════════════════════════════════════════════\n81|#  状态检查\n82|# ═══════════════════════════════════════════════\n83|\n84|check_port() {\n85|    lsof -ti :\"$1\" >/dev/null 2>&1\n86|}\n87|\n88|status() {\n89|    echo \"\"\n90|    echo \"═══ 坐山客服务状态 ═══\"\n91|    echo \"\"\n92|\n93|    # 后端\n94|    if check_port \"$BACKEND_PORT\"; then\n95|        local pid=$(lsof -ti :$BACKEND_PORT 2>/dev/null)\n96|        log_ok \"后端 http://localhost:$BACKEND_PORT (PID: $pid)\"\n97|        if curl -sf http://localhost:$BACKEND_PORT/api/channels >/dev/null 2>&1; then\n98|            echo \"   └─ API 正常\"\n99|        else\n100|            log_warn \"   └─ API 无响应\"\n101|        fi\n102|    else\n103|        log_err \"后端 :$BACKEND_PORT — 未运行\"\n104|    fi\n105|\n106|    # 前端\n107|    if check_port \"$FRONTEND_PORT\"; then\n108|        local pid=$(lsof -ti :$FRONTEND_PORT 2>/dev/null)\n109|        log_ok \"前端 http://localhost:$FRONTEND_PORT (PID: $pid)\"\n110|    else\n111|        log_err \"前端 :$FRONTEND_PORT — 未运行\"\n112|    fi\n113|\n114|    # Gateway (Hermes)\n115|    if pgrep -f \"hermes_cli.*gateway\" >/dev/null 2>&1; then\n116|        local pid=$(pgrep -f \"hermes_cli.*gateway\" 2>/dev/null | head -1)\n117|        log_ok \"Gateway (PID: $pid)\"\n118|    else\n119|        log_err \"Gateway — 未运行\"\n120|    fi\n121|\n122|    # Qwen LLM\n123|    if check_port 8083; then\n124|        log_ok \"Qwen LLM :8083\"\n125|    else\n126|        log_warn \"Qwen LLM :8083 — 未运行（用 start-qwen.sh 启动）\"\n127|    fi\n128|}\n129|\n130|# ═══════════════════════════════════════════════\n131|#  启动\n132|# ═══════════════════════════════════════════════\n133|\n134|start_backend() {\n135|    echo \"\"\n136|    echo \"🚀 启动后端 http://localhost:$BACKEND_PORT ...\"\n137|\n138|    # 检查目录\n139|    if [ ! -d \"$BACKEND_DIR\" ]; then\n140|        log_err \"后端目录不存在: $BACKEND_DIR\"\n141|        exit 1\n142|    fi\n143|    if [ ! -f \"$BACKEND_DIR/.venv/bin/python\" ]; then\n144|        log_err \"虚拟环境不存在: $BACKEND_DIR/.venv\"\n145|        exit 1\n146|    fi\n147|\n148|    cd \"$BACKEND_DIR\"\n149|    nohup .venv/bin/python main.py > \"$BACKEND_LOG\" 2>&1 &\n150|    local pid=$!\n151|    log_info \"PID: $pid，日志: $BACKEND_LOG\"\n152|\n153|    # 等待启动（最多 15 秒）\n154|    for i in $(seq 1 15); do\n155|        sleep 1\n156|        if curl -sf http://localhost:$BACKEND_PORT/api/channels >/dev/null 2>&1; then\n157|            log_ok \"后端启动成功（${i}s）\"\n158|            return 0\n159|        fi\n160|    done\n161|\n162|    log_err \"后端启动超时，日志最后 10 行:\"\n163|    tail -10 \"$BACKEND_LOG\" 2>/dev/null\n164|    return 1\n165|}\n166|\n167|start_frontend() {\n168|    echo \"\"\n169|    echo \"🚀 启动前端 http://localhost:$FRONTEND_PORT ...\"\n170|\n171|    if [ ! -d \"$FRONTEND_DIR\" ]; then\n172|        log_err \"前端目录不存在: $FRONTEND_DIR\"\n173|        exit 1\n174|    fi\n175|    if [ ! -f \"$PNPM\" ]; then\n176|        log_err \"pnpm 不存在: $PNPM\"\n177|        exit 1\n178|    fi\n179|\n180|    cd \"$FRONTEND_DIR\"\n181|    nohup node ./node_modules/vite/bin/vite.js --host 0.0.0.0 > \"$FRONTEND_LOG\" 2>&1 &\n182|    local pid=$!\n183|    log_info \"PID: $pid，日志: $FRONTEND_LOG\"\n184|\n185|    # 等待启动（最多 30 秒，Vite 编译慢）\n186|    for i in $(seq 1 30); do\n187|        sleep 1\n188|        if check_port \"$FRONTEND_PORT\"; then\n189|            log_ok \"前端启动成功（${i}s）\"\n190|            return 0\n191|        fi\n192|    done\n193|\n194|    log_err \"前端启动超时，日志最后 10 行:\"\n195|    tail -10 \"$FRONTEND_LOG\" 2>/dev/null\n196|    return 1\n197|}\n198|\n199|start_gateway() {\n200|    echo \"\"\n201|    echo \"🚀 启动 Hermes Gateway ...\"\n202|\n203|    if pgrep -f \"hermes_cli.*gateway\" >/dev/null 2>&1; then\n204|        log_warn \"Gateway 已在运行\"\n205|        return 0\n206|    fi\n207|\n208|    nohup python3 -m hermes_cli.main gateway run --replace > \"$GATEWAY_LOG\" 2>&1 &\n209|    local pid=$!\n210|    log_info \"PID: $pid，日志: $GATEWAY_LOG\"\n211|\n212|    # 等待启动（最多 10 秒）\n213|    for i in $(seq 1 10); do\n214|        sleep 1\n215|        if pgrep -f \"hermes_cli.*gateway\" >/dev/null 2>&1; then\n216|            log_ok \"Gateway 启动成功（${i}s）\"\n217|            return 0\n218|        fi\n219|    done\n220|\n221|    log_err \"Gateway 启动失败，日志:\"\n222|    tail -5 \"$GATEWAY_LOG\" 2>/dev/null\n223|    return 1\n224|}\n225|\n226|# ═══════════════════════════════════════════════\n227|#  主流程\n228|# ═══════════════════════════════════════════════\n229|\n230|case \"${1:-all}\" in\n231|    stop)\n232|        stop_all\n233|        exit 0\n234|        ;;\n235|    status)\n236|        status\n237|        exit 0\n238|        ;;\n239|    restart)\n240|        stop_all\n241|        sleep 2\n242|        exec \"$0\" \"${2:-all}\"\n243|        ;;\n244|    backend)\n245|        start_backend\n246|        ;;\n247|    frontend)\n248|        start_frontend\n249|        ;;\n250|    gateway)\n251|        start_gateway\n252|        ;;\n253|    all|\"\")\n254|        start_backend\n255|        start_frontend\n256|        start_gateway\n257|        echo \"\"\n258|        log_ok \"全部服务启动完成\"\n259|        echo \"\"\n260|        status\n261|        ;;\n262|    *)\n263|        echo \"用法: $0 {all|backend|frontend|gateway|stop|status|restart}\"\n264|        echo \"\"\n265|        echo \"  all        启动全部（后端 + 前端 + Gateway）\"\n266|        echo \"  backend    仅后端\"\n267|        echo \"  frontend   仅前端\"\n268|        echo \"  gateway    仅消息网关\"\n269|        echo \"  stop       全部停止\"\n270|        echo \"  status     查看状态\"\n271|        echo \"  restart    全部重启\"\n272|        exit 1\n273|        ;;\n274|esac", "total_lines": 274, "offset": 1, "limit": 500}, "duration_ms": 6}
